#include <stdio.h>
#include <locale.h>
#include <stdlib.h>

int main() {
    setlocale(0, "");
    int numz, numo;
    printf("Введите число, которое хотите загадать\t");
    scanf_s("%d", &numz);
    if (numz > 100 or numz < 0) {
        printf("Число вне диапазона\n");
    }
    printf("Введите ваше предположение\t ");
    scanf_s("%d", &numo);
    while (numo != numz) {
        printf("Вы не угадали попробуйте еще раз\n");
        if (numo > numz) {
            printf("Меньше\n");
        }
        else {
            printf("Больше\n");
        }
        scanf_s("%d", &numo);
    }

    printf("Ура победа!!!!!0|0\n");
    system("pause");
    return 0;
}